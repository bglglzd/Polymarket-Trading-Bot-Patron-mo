# PolyPatronBot Environment Variables
# Copy this to .env and fill in your values

# ── Trading Mode ──────────────────────────────────────────────
ENABLE_LIVE_TRADING=false

# ── Polymarket API (required for live trading) ────────────────
# POLYMARKET_API_KEY=your_api_key_here
# POLYMARKET_API_SECRET=your_api_secret_here

# ── AI Analysis ───────────────────────────────────────────────
# Powered by Codex CLI — login with: codex login
# No API key needed, uses your Codex subscription

# ── Telegram Notifications ────────────────────────────────────
# Get token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=production
