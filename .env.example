# PolyPatronBot Environment Variables
# Copy this to .env and fill in your values

# ── Trading Mode ──────────────────────────────────────────────
# Set to 'true' to enable live trading (requires config.yaml enable_live_trading: true)
ENABLE_LIVE_TRADING=false

# ── Polymarket API ────────────────────────────────────────────
# Required for live trading. Get from https://polymarket.com
# POLYMARKET_API_KEY=your_api_key_here
# POLYMARKET_API_SECRET=your_api_secret_here

# ── Claude AI Analysis ────────────────────────────────────────
# Powers the AI Forecast strategy with Claude analysis
# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ── Node Environment ──────────────────────────────────────────
NODE_ENV=production
